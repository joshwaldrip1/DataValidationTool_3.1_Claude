            <Item>SET-ON WEIGHTS</Item>
            <Item>WEIGHTS OR HOLD-DOWN</Item>
            <Item>UNDETERMINED</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="WEIGHT LBS" EntryMethod="Optional" IsLabelVisible="true" />
        <StringAttribute Name="DESCRIPTION" EntryMethod="Optional" IsLabelVisible="true" />
        <StringAttribute Name="REMARKS" EntryMethod="Optional" IsLabelVisible="true" MaximumLength="254" />
      </Attributes>
    </PointFeatureDefinition>
    <PointFeatureDefinition Code="WELD" Name="WELD" Category="Data Dictionary File" IncludeInSurface="false" Color="FE000000" Layer="0" PointLabelStyle="">
      <Attributes>
        <ListAttribute Name="TYPE" EntryMethod="Required" IsLabelVisible="true" DefaultItemIndex="0">
          <ListItems>
            <Item>MAINLINE</Item>
            <Item>BORE PIPE</Item>
            <Item>FABRICATION</Item>
            <Item>OTHER (SEE REMARK)</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="XRAY" EntryMethod="Required" IsLabelVisible="true" />
        <StringAttribute Name="JOINT AHEAD" Description="TALLY NUMBER AHEAD" EntryMethod="Required" IsLabelVisible="true" />
        <StringAttribute Name="JOINT BACK" Description="TALLY NUMBER BACK" EntryMethod="Required" IsLabelVisible="true" />
        <StringAttribute Name="HEAT AHEAD" EntryMethod="Required" IsLabelVisible="true" />
        <StringAttribute Name="HEAT BACK" EntryMethod="Required" IsLabelVisible="true" />
        <DoubleAttribute Name="JOINT LENGTH" Description="LENGTH OF JOINT AHEAD" EntryMethod="Required" IsLabelVisible="true" MinimumValue="-1.7976931348623157E+308" MaximumValue="1.7976931348623157E+308" NumberOfDecimals="2" />
        <DoubleAttribute Name="DEPTH OF COVER" EntryMethod="Required" IsLabelVisible="true" MinimumValue="-1.7976931348623157E+308" MaximumValue="1.7976931348623157E+308" NumberOfDecimals="1" />
        <ListAttribute Name="PIPE MATERIAL" Description="COATING PROCESS OVER WELD" EntryMethod="Required" IsLabelVisible="true">
          <ListItems>
            <Item>STEEL</Item>
            <Item>POLY</Item>
            <Item>FLEX STEEL</Item>
            <Item>PLASTIC</Item>
            <Item>STAINLESS STEEL</Item>
            <Item>OTHER (SEE REMARK)</Item>
          </ListItems>
        </ListAttribute>
        <ListAttribute Name="PIPE COATING" Description="TYPE OF COATING ON PIPE" EntryMethod="Required" IsLabelVisible="true">
          <ListItems>
            <Item>FUSION BONDED EPOXY</Item>
            <Item>FBE AND ARO</Item>
            <Item>BARE</Item>
            <Item>PAINT</Item>
            <Item>EXTRUDED PE XTRUCOA</Item>
            <Item>POLYURETHANE</Item>
            <Item>POWERCRETE</Item>
            <Item>UNDETERMINED</Item>
            <Item>OTHER (SEE REMARK)</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="BASECOAT (FBE) MILLS" Description="BASE COATING MILLS USUALLY 14-16" EntryMethod="Required" IsLabelVisible="true" MaximumLength="15" />
        <StringAttribute Name="OVERCOAT (ARO) MILLS" Description="OVERCOAT COATING MILLS USUALLY 30-40" EntryMethod="Required" IsLabelVisible="true" MaximumLength="15" />
        <StringAttribute Name="MANUFACTURER" Description="PIPE MAKER (NOT COATING MAKER)" EntryMethod="Required" IsLabelVisible="true" />
        <DoubleAttribute Name="DIAMETER" EntryMethod="Required" IsLabelVisible="true" MinimumValue="-1.7976931348623157E+308" MaximumValue="1.7976931348623157E+308" NumberOfDecimals="3" />
        <DoubleAttribute Name="WALL THICKNESS" EntryMethod="Required" IsLabelVisible="true" MinimumValue="-1.7976931348623157E+308" MaximumValue="1.7976931348623157E+308" NumberOfDecimals="3" />
        <StringAttribute Name="GRADE" Description="EXAMPLE X52, X65, WPHY" EntryMethod="Required" IsLabelVisible="true" />
        <ListAttribute Name="SEAM" Description="LONG SEAM - WELD TYPE" EntryMethod="Required" IsLabelVisible="true">
          <ListItems>
            <Item>ERW</Item>
            <Item>HFW</Item>
            <Item>SEAMLESS</Item>
            <Item>UNDETERMINED</Item>
            <Item>OTHER (SEE REMARK)</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="WELDER NO" Description="WELDER NUMBER OR INITIALS" EntryMethod="Required" IsLabelVisible="true" MaximumLength="50" />
        <StringAttribute Name="REMARKS" EntryMethod="Optional" IsLabelVisible="true" MaximumLength="254" />
      </Attributes>
    </PointFeatureDefinition>
