  <FeatureDefinitions>
    <LineFeatureDefinition Code="ACCESS_ROAD" Name="ACCESS_ROAD" Category="FIELD CODES" IncludeInSurface="true" Color="FE000000" Layer="ODS_OPS_FEUD_STD_ACCESS_ROAD" FieldLineStyle="Solid" LineStyleName="Solid" LineStyleScale="1" LineLabelStyle="" PointLabelStyle="" PointLayer="0">
      <Attributes>
        <StringAttribute Name="WIDTH" Description="WIDTH" EntryMethod="Required" Alias="WIDTH" IsLabelVisible="true" MaximumLength="50" />
        <ListAttribute Name="STATUS" Description="Active, Inactive, Temporary" EntryMethod="Required" IsLabelVisible="true" DefaultItemIndex="0">
          <ListItems>
            <Item>Active</Item>
            <Item>Inactive</Item>
            <Item>Temporary</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="NOTE" Description="NOTE" EntryMethod="Required" Alias="NOTE" IsLabelVisible="true" MaximumLength="250" />
        <StringAttribute Name="COMMENTS" Description="COMMENTS" EntryMethod="Required" Alias="COMMENTS" IsLabelVisible="true" MaximumLength="250" />
        <ListAttribute Name="DEV_AREA_NAME" Description="DEV_AREA_NAME" EntryMethod="Required" IsLabelVisible="true">
          <ListItems>
            <Item>Central Basin Platform</Item>
            <Item>East Texas</Item>
