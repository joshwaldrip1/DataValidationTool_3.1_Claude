        <ListAttribute Name="TYPE" EntryMethod="Required">
          <ListItems>
            <Item>ELECTRIC</Item>
            <Item>MECHANICAL</Item>
            <Item>PEDESTRIAN</Item>
            <Item>TRANSPORTATION</Item>
            <Item>OTHER (SEE NOTES)</Item>
          </ListItems>
        </ListAttribute>
        <ListAttribute Name="POSITION" EntryMethod="Required">
          <ListItems>
            <Item>BOTTOM</Item>
            <Item>CORNER</Item>
            <Item>EDGE</Item>
            <Item>OTHER (SEE NOTES)</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="NOTES" EntryMethod="Optional" />
      </Attributes>
    </PointFeatureDefinition>
    <PointFeatureDefinition Code="VENT" Name="VENT PIPE" Category="Data Dictionary File" IncludeInSurface="true" Color="FE000000" Layer="0">
      <Attributes>
        <ListAttribute Name="TEST_LEAD_ATTACHED" EntryMethod="Required">
          <ListItems>
            <Item>NO</Item>
            <Item>YES</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="MANUFACTURER" EntryMethod="Optional" />
        <DoubleAttribute Name="DIAMETER" EntryMethod="Required" DefaultValue="0" MinimumValue="0" MaximumValue="10000" />
        <StringAttribute Name="COMPANY" EntryMethod="Required" />
        <StringAttribute Name="NOTES" EntryMethod="Optional" />
      </Attributes>
    </PointFeatureDefinition>
    <PointFeatureDefinition Code="WALL" Name="WALL" Category="Data Dictionary File" IncludeInSurface="true" Color="FE000000" Layer="0">
      <Attributes>
        <ListAttribute Name="TYPE" EntryMethod="Required">
          <ListItems>
            <Item>BULKHEAD</Item>
            <Item>RETAINING</Item>
            <Item>SOUND</Item>
            <Item>OTHER (SEE NOTES)</Item>
          </ListItems>
        </ListAttribute>
        <ListAttribute Name="MATERIAL" EntryMethod="Required">
          <ListItems>
            <Item>BRICK</Item>
            <Item>CINDER BLOCK</Item>
            <Item>CONCRETE</Item>
            <Item>ROCK</Item>
            <Item>SHEET PILING</Item>
            <Item>STONE</Item>
            <Item>OTHER (SEE NOTES)</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="NOTES" EntryMethod="Optional" />
      </Attributes>
    </PointFeatureDefinition>
    <PointFeatureDefinition Code="WATERBODY" Name="WATERBODY" Category="Data Dictionary File" IncludeInSurface="true" Color="FE000000" Layer="0">
      <Attributes>
        <ListAttribute Name="TYPE" EntryMethod="Required">
          <ListItems>
            <Item>BAYOU</Item>
            <Item>CANAL</Item>
            <Item>CANYON</Item>
            <Item>CREEK</Item>
            <Item>DITCH</Item>
            <Item>DRAIN</Item>
            <Item>LAKE</Item>
            <Item>LEVEE</Item>
            <Item>MARSH</Item>
            <Item>OCEAN</Item>
            <Item>PIT</Item>
            <Item>POND</Item>
            <Item>RIVER</Item>
            <Item>STREAM</Item>
            <Item>SWAMP</Item>
            <Item>WASH</Item>
            <Item>OTHER (SEE NOTES)</Item>
            <Item>GULLY</Item>
            <Item>RESEVOIR</Item>
            <Item>SLOUGH</Item>
          </ListItems>
        </ListAttribute>
        <ListAttribute Name="POSITION" EntryMethod="Required">
          <ListItems>
            <Item>BOTTOM</Item>
            <Item>EDGE</Item>
            <Item>SOUNDING</Item>
            <Item>OTHER (SEE NOTES)</Item>
          </ListItems>
        </ListAttribute>
        <DoubleAttribute Name="WIDTH" EntryMethod="Required" DefaultValue="0" MinimumValue="-1.79E+308" MaximumValue="1.79E+308" />
        <DoubleAttribute Name="DEPTH" EntryMethod="Required" DefaultValue="0" MinimumValue="-1.79E+308" MaximumValue="1.79E+308" />
        <StringAttribute Name="NAME" EntryMethod="Optional" />
        <ListAttribute Name="FLOW_DIRECTION" EntryMethod="Required">
          <ListItems>
            <Item>EAST - WEST LINE CROSSING</Item>
            <Item>NORTH - SOUTH LINE CROSSING</Item>
            <Item>NORTHEAST - SOUTHWEST LINE CROSSING</Item>
            <Item>NORTHWEST - SOUTHEAST LINE CROSSING</Item>
            <Item>OTHER (SEE NOTES)</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="NOTES" EntryMethod="Optional" />
      </Attributes>
    </PointFeatureDefinition>
    <PointFeatureDefinition Code="WELD" Name="WELD (PIPE JOIN)" Category="Data Dictionary File" IncludeInSurface="true" Color="FE000000" Layer="0">
      <Attributes>
        <ListAttribute Name="TYPE" EntryMethod="Required">
          <ListItems>
            <Item>BUTT JOINT</Item>
            <Item>LAP JOINT</Item>
            <Item>FILLET WELD</Item>
            <Item>ELECTROFUSION</Item>
            <Item>COUPLING</Item>
            <Item>THREADED</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="XRAY_NUMBER" Description="XRAY NUMBER OF WELD" EntryMethod="Required" />
        <StringAttribute Name="JOINT_AHEAD" Description="JOINT NUMBER AHEAD" EntryMethod="Required" />
        <StringAttribute Name="JOINT_BACK" Description="JOINT NUMBER BEHIND" EntryMethod="Required" />
        <StringAttribute Name="HEAT_AHEAD" Description="PIPE HEAT AHEAD" EntryMethod="Required" />
        <StringAttribute Name="HEAT_BACK" Description="PIPE HEAT BEHIND" EntryMethod="Required" />
        <DoubleAttribute Name="DOC" Description="DEPTH OF COVER" EntryMethod="Required" DefaultValue="0" MinimumValue="-1.79E+308" MaximumValue="1.79E+308" NumberOfDecimals="1" />
        <StringAttribute Name="JOINT_ID" Description="SERIAL OR PIPE NUMBER AHEAD" EntryMethod="Required" />
        <StringAttribute Name="WALLTHICKNESS" Description="PIPE WALL THICKNESS" EntryMethod="Required" />
        <StringAttribute Name="COATING_TYPE" Description="EXAMPLE - FBE ARO PAINT BARE" EntryMethod="Required" />
        <ListAttribute Name="MATERIAL" Description="PIPE MATERIAL" EntryMethod="Required">
          <ListItems>
            <Item>STEEL</Item>
            <Item>HIGH DENSITY POLY ETHYLENE</Item>
            <Item>OTHER (SEE NOTES)</Item>
          </ListItems>
        </ListAttribute>
        <StringAttribute Name="DIAMETER" Description="PIPE DIAMETER" EntryMethod="Required" />
        <StringAttribute Name="GRADE" Description="EXAMPLE - X42 X52 Y52 WPB" EntryMethod="Required" />
        <StringAttribute Name="PIPE_SPECS" Description="EXAMPLE - API5L ASTM105" EntryMethod="Required" />
        <StringAttribute Name="LENGTH" Description="LENGTH AHEAD" EntryMethod="Required" />
        <StringAttribute Name="MANUFACTURER" Description="PIPE MANUFACTURER" EntryMethod="Required" />
        <StringAttribute Name="WELDER" Description="WELDER INITIALS/STENCIL" EntryMethod="Required" DefaultValue="0" MaximumLength="500" />
        <DateAttribute Name="INSTALLATION_DATE" EntryMethod="AutoGenerate" AnnotationFormat="d" />
        <StringAttribute Name="NOTES" EntryMethod="Optional" />
      </Attributes>
    </PointFeatureDefinition>
    <PointFeatureDefinition Code="WELL" Name="WELL" Category="Data Dictionary File" IncludeInSurface="true" Color="FE000000" Layer="0">
